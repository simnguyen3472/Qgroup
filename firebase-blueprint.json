{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post for the travel website.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "number", "description": "Server timestamp" },
        "updatedAt": { "type": "number", "description": "Server timestamp" },
        "authorId": { "type": "string", "description": "UID of the admin who created it" }
      },
      "required": ["title", "excerpt", "content", "date", "authorId", "createdAt", "updatedAt"]
    },
    "FleetCar": {
      "title": "Fleet Car",
      "description": "A vehicle available for rent.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "seats": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "authorId": { "type": "string" }
      },
      "required": ["name", "image", "seats", "description", "createdAt", "updatedAt", "authorId"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the website.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/blog_posts/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Stores all blog posts."
    },
    "/fleet_cars/{carId}": {
      "schema": { "$ref": "#/entities/FleetCar" },
      "description": "Stores all vehicles."
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Stores admin users. Document ID is the user UID."
    }
  }
}
